<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- CFBundle* keys are intentionally omitted: the target has
	     GENERATE_INFOPLIST_FILE=YES with INFOPLIST_KEY_* build settings, and
	     duplicating those keys here fails the build. Only the widget-specific
	     keys live in this physical plist. -->
	<key>NSExtension</key>
	<dict>
		<key>NSExtensionPointIdentifier</key>
		<string>com.apple.widgetkit-extension</string>
	</dict>
	<!-- Required so the extension can host the Live Activity's ActivityConfiguration
	     (Duʿā-times ticking countdown). Apple + the live_activities README both
	     require NSSupportsLiveActivities=YES on BOTH the app (Runner) and the
	     Widget Extension. See docs/superpowers/plans/2026-07-16-dua-live-activities.md §6. -->
	<key>NSSupportsLiveActivities</key>
	<true/>
	<!-- Fonts must be bundled in the extension target — the app's runtime
	     google_fonts are invisible to the widget process. TTFs live in
	     ios/SakinaWidget/Fonts/ (auto-synced via the file-system-synchronized
	     group). Outfit is the app's Latin UI font (AppTypography = GoogleFonts
	     .outfit); it's variable, so weights come from SwiftUI .fontWeight().
	     Aref Ruqaa = Arabic Name hero; Amiri reserved for verse text. -->
	<key>UIAppFonts</key>
	<array>
		<string>ArefRuqaa-Regular.ttf</string>
		<string>Amiri-Regular.ttf</string>
		<string>Outfit.ttf</string>
	</array>
</dict>
</plist>
